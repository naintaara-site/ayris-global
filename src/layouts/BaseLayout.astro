---
import '../styles/global.css';
/**
 * BaseLayout.astro
 * Master shell for every page on ayrisglobal.in
 * Includes: SEO meta | Navbar | <slot /> | Footer | WhatsApp float
 *
 * Props:
 *   title       — Page title (shown in browser tab + Google)
 *   description — Meta description (shown in Google snippets)
 *   canonical   — Full canonical URL for this page
 *   ogImage     — Open Graph image (defaults to /og-image.jpg)
 */

interface Props {
  title:       string;
  description: string;
  canonical?:  string;
  ogImage?:    string;
}

const {
  title,
  description,
  canonical  = `https://ayrisglobal.in${Astro.url.pathname}`,
  ogImage    = '/og-image.jpg',
} = Astro.props;

const fullTitle = title === 'Home'
  ? 'Ayris Global — Premium Indian Wellness Ingredients for International Buyers'
  : `${title} | Ayris Global`;

// Nav links — update href if URL structure ever changes
const navLinks = [
  { label: 'For Buyers',  href: '/for-buyers/' },
  { label: 'Products',    href: '/products/'   },
  { label: 'Why India',   href: '/why-india/'  },
  { label: 'Quality',     href: '/quality/'    },
  { label: 'About',       href: '/about/'      },
  { label: 'Blog',        href: '/blog/'       },
];

// WhatsApp number — replace +919729256621 with real number before going live
const whatsappNumber = '+919729256621';
const whatsappMessage = encodeURIComponent('Hello Ayris Global, I am interested in sourcing Indian wellness ingredients. Please share more details.');
const whatsappURL = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- ═══════════════════════════════════════
       CORE META
  ═══════════════════════════════════════ -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="keywords"    content="Indian wellness ingredients, Ayurvedic extracts, herbal ingredients export, botanical powders India, nutraceutical sourcing, essential oils India, B2B wellness sourcing" />
  <meta name="author"      content="Ayris Global" />
  <meta name="robots"      content="index, follow" />
  <link rel="canonical"    href={canonical} />

  <!-- ═══════════════════════════════════════
       OPEN GRAPH (LinkedIn, WhatsApp previews)
  ═══════════════════════════════════════ -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={`https://ayrisglobal.in${ogImage}`} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name"   content="Ayris Global" />
  <meta property="og:locale"      content="en_US" />

  <!-- ═══════════════════════════════════════
       TWITTER / X CARD
  ═══════════════════════════════════════ -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={`https://ayrisglobal.in${ogImage}`} />

  <!-- ═══════════════════════════════════════
       FAVICON
  ═══════════════════════════════════════ -->
  <link rel="icon"             type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <!-- ═══════════════════════════════════════
       FONTS — preconnect for speed
  ═══════════════════════════════════════ -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- ═══════════════════════════════════════
       GLOBAL STYLES
  ═══════════════════════════════════════ -->
  <link rel="stylesheet" href="/src/styles/global.css" />

  <!-- ═══════════════════════════════════════
       SCHEMA MARKUP — Organisation
  ═══════════════════════════════════════ -->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Ayris Global",
      "url": "https://ayrisglobal.in",
      "logo": "https://ayrisglobal.in/logo.png",
      "description": "Premium Indian wellness ingredient sourcing for international buyers. Specialising in Ayurvedic extracts, herbal ingredients, botanical powders, and nutraceuticals.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mumbai",
        "addressCountry": "IN"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "sourcing@ayrisglobal.in",
        "contactType": "sales"
      },
      "sameAs": []
    })}
  </script>
</head>

<body>

  <!-- ═══════════════════════════════════════
       NAVBAR
  ═══════════════════════════════════════ -->
  <header class="navbar" id="navbar">
    <div class="navbar__inner">

      <!-- Logo -->
      <a href="/" class="navbar__logo" aria-label="Ayris Global — Home">
        <img src="/logo.png" alt="Ayris Global" width="160" height="42" />
      </a>

      <!-- Desktop navigation links -->
      <nav class="navbar__links" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`navbar__link ${currentPath === link.href ? 'active' : ''}`}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop actions -->
      <div class="navbar__actions">

        <!-- WhatsApp -->
        <a
          href={whatsappURL}
          target="_blank"
          rel="noopener noreferrer"
          class="navbar__whatsapp"
          aria-label="Chat on WhatsApp"
        >
          <!-- WhatsApp SVG icon -->
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span>WhatsApp</span>
        </a>

        <!-- Enquiry CTA -->
        <a href="/contact/" class="btn btn--primary btn--sm">
          Submit Enquiry
        </a>

      </div>

      <!-- Mobile: WhatsApp icon + hamburger -->
      <div style="display:flex; align-items:center; gap:0.75rem;">
        <a
          href={whatsappURL}
          target="_blank"
          rel="noopener noreferrer"
          class="navbar__whatsapp"
          aria-label="Chat on WhatsApp"
          style="display:none;"
          id="whatsapp-mobile-nav"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>

        <button
          class="navbar__toggle"
          id="menu-toggle"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

    </div><!-- /.navbar__inner -->

    <!-- Mobile dropdown menu -->
    <nav class="navbar__mobile" id="mobile-menu" aria-label="Mobile navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`navbar__mobile-link ${currentPath === link.href ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact/"
        class="btn btn--primary"
        style="margin-top: 0.5rem; text-align:center; justify-content:center;"
      >
        Submit Enquiry
      </a>
    </nav>

  </header><!-- /.navbar -->


  <!-- ═══════════════════════════════════════
       PAGE CONTENT — injected by each page
  ═══════════════════════════════════════ -->
  <main id="main-content">
    <slot />
  </main>


  <!-- ═══════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════ -->
  <footer class="footer">
    <div class="container">

      <div class="footer__grid">

        <!-- Brand column -->
        <div class="footer__brand">
          <a href="/" aria-label="Ayris Global — Home">
            <img src="/logo.png" alt="Ayris Global" width="148" height="40" />
          </a>
          <p class="footer__tagline">Intelligence. Connection. Growth.</p>
          <p class="footer__description">
            Bridging India's finest wellness producers with international buyers.
            Verified ingredients. Transparent sourcing. Trusted relationships.
          </p>
        </div>

        <!-- Quick links -->
        <div>
          <p class="footer__heading">Source</p>
          <ul class="footer__links">
            <li><a href="/for-buyers/"   class="footer__link">For Buyers</a></li>
            <li><a href="/for-suppliers/" class="footer__link">For Suppliers</a></li>
            <li><a href="/products/"     class="footer__link">Product Categories</a></li>
            <li><a href="/why-india/"    class="footer__link">Why India</a></li>
            <li><a href="/quality/"      class="footer__link">Quality Standards</a></li>
          </ul>
        </div>

        <!-- Company -->
        <div>
          <p class="footer__heading">Company</p>
          <ul class="footer__links">
            <li><a href="/about/"   class="footer__link">About Us</a></li>
            <li><a href="/blog/"    class="footer__link">Insights</a></li>
            <li><a href="/contact/" class="footer__link">Contact</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div>
          <p class="footer__heading">Contact</p>
          <ul class="footer__links">
            <li>
              <a href="mailto:sourcing@ayrisglobal.in" class="footer__link">
                sourcing@ayrisglobal.in
              </a>
            </li>
            <li>
              <a href="mailto:partnerships@ayrisglobal.in" class="footer__link">
                partnerships@ayrisglobal.in
              </a>
            </li>
            <li>
              <a
                href={whatsappURL}
                target="_blank"
                rel="noopener noreferrer"
                class="footer__link"
              >
                WhatsApp Us
              </a>
            </li>
            <li style="color: rgba(250,250,248,0.35); font-size: 0.8rem; margin-top: 0.5rem;">
              Mumbai, India
            </li>
          </ul>
        </div>

      </div><!-- /.footer__grid -->

      <!-- Bottom bar -->
      <div class="footer__bottom">
        <p class="footer__copyright">
          &copy; {new Date().getFullYear()} Ayris Global. All rights reserved.
        </p>
        <nav class="footer__legal" aria-label="Legal links">
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/terms/">Terms of Use</a>
        </nav>
      </div>

    </div><!-- /.container -->
  </footer><!-- /.footer -->


  <!-- ═══════════════════════════════════════
       WHATSAPP FLOATING BUTTON
  ═══════════════════════════════════════ -->
  <a
    href={whatsappURL}
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-float"
    aria-label="Chat with Ayris Global on WhatsApp"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="whatsapp-float__text">Chat with us</span>
  </a>


  <!-- ═══════════════════════════════════════
       JAVASCRIPT — Navbar scroll + mobile menu
  ═══════════════════════════════════════ -->
  <script>
    // ── Navbar: add shadow on scroll ──
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar?.classList.add('scrolled');
      } else {
        navbar?.classList.remove('scrolled');
      }
    }, { passive: true });

    // ── Mobile menu toggle ──
    const toggle   = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileWA   = document.getElementById('whatsapp-mobile-nav');

    // Show WhatsApp icon on mobile nav (CSS hides it by default)
    const showMobileWA = () => {
      if (window.innerWidth <= 768 && mobileWA) {
        mobileWA.style.display = 'flex';
      }
    };
    showMobileWA();
    window.addEventListener('resize', showMobileWA, { passive: true });

    toggle?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.contains('open');
      mobileMenu?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(!isOpen));

      // Animate hamburger → X
      const spans = toggle.querySelectorAll('span');
      if (!isOpen) {
        spans[0].style.transform = 'translateY(7px) rotate(45deg)';
        spans[1].style.opacity   = '0';
        spans[2].style.transform = 'translateY(-7px) rotate(-45deg)';
      } else {
        spans[0].style.transform = '';
        spans[1].style.opacity   = '';
        spans[2].style.transform = '';
      }
    });

    // Close mobile menu when a link is clicked
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
        const spans = toggle?.querySelectorAll('span');
        if (spans) {
          spans[0].style.transform = '';
          spans[1].style.opacity   = '';
          spans[2].style.transform = '';
        }
      });
    });
  </script>

</body>
</html>

