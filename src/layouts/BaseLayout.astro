---
import '../styles/global.css';

interface Props {
  title:       string;
  description: string;
  canonical?:  string;
  ogImage?:    string;
}

const {
  title,
  description,
  canonical  = `https://ayrisglobal.in${Astro.url.pathname}`,
  ogImage    = '/og-image.jpg',
} = Astro.props;

const fullTitle = title === 'Home'
  ? 'Ayris Global - Premium Indian Wellness Ingredients for International Buyers'
  : `${title} | Ayris Global`;

const navLinks = [
  { label: 'For Buyers',  href: '/for-buyers/' },
  { label: 'Products',    href: '/products/'   },
  { label: 'Why India',   href: '/why-india/'  },
  { label: 'Quality',     href: '/quality/'    },
  { label: 'About',       href: '/about/'      },
  { label: 'Blog',        href: '/blog/'       },
];

const whatsappNumber = '+919729256621';
const whatsappMessage = encodeURIComponent('Hello Ayris Global, I am interested in sourcing Indian wellness ingredients. Please share more details.');
const whatsappURL = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
const currentPath = Astro.url.pathname;
const orgSchemaJson = "{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Ayris Global\",\"url\":\"https://ayrisglobal.in\",\"logo\":\"https://ayrisglobal.in/logo.png\",\"description\":\"Premium Indian wellness ingredient sourcing for international buyers.\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Mumbai\",\"addressCountry\":\"IN\"},\"contactPoint\":{\"@type\":\"ContactPoint\",\"email\":\"sourcing@ayrisglobal.in\",\"contactType\":\"sales\"},\"sameAs\":[]}";

// BreadcrumbList structured data (skip homepage)
const pathname = Astro.url.pathname;
const breadcrumbItems = [];

if (pathname !== '/') {
  breadcrumbItems.push({ name: 'Home', url: 'https://ayrisglobal.in/' });

  const isBlogPost = pathname.startsWith('/blog/') && pathname !== '/blog/';
  if (isBlogPost) {
    breadcrumbItems.push({ name: 'Blog', url: 'https://ayrisglobal.in/blog/' });
    breadcrumbItems.push({ name: title, url: 'https://ayrisglobal.in' + pathname });
  } else if (pathname === '/blog/') {
    breadcrumbItems.push({ name: 'Blog', url: 'https://ayrisglobal.in/blog/' });
  } else {
    breadcrumbItems.push({ name: title, url: 'https://ayrisglobal.in' + pathname });
  }
}

const breadcrumbSchemaJson = breadcrumbItems.length > 0
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems.map((item, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": item.name,
        "item": item.url,
      })),
    })
  : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="Indian wellness ingredients, Ayurvedic extracts, herbal ingredients export, botanical powders India, nutraceutical sourcing, essential oils India, B2B wellness sourcing" />
  <meta name="author" content="Ayris Global" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://ayrisglobal.in${ogImage}`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Ayris Global" />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://ayrisglobal.in${ogImage}`} />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <!-- <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin /> -->
  <script type="application/ld+json" set:html={orgSchemaJson} />
  {breadcrumbSchemaJson && <script type="application/ld+json" set:html={breadcrumbSchemaJson} />}
  <slot name="head" />
</head>

<body>

  <header class="navbar" id="navbar">
    <div class="navbar__inner">

      <a href="/" class="navbar__logo" aria-label="Ayris Global - Home">
        <img src="/logo.png" alt="Ayris Global" width="160" height="42" />
      </a>

      <nav class="navbar__links" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`navbar__link ${currentPath === link.href ? 'active' : ''}`}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="navbar__actions">
        <a
          href={whatsappURL}
          target="_blank"
          rel="noopener noreferrer"
          class="navbar__whatsapp"
          aria-label="Chat on WhatsApp"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.555 4.122 1.528 5.855L0 24l6.335-1.652A11.954 11.954 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.003-1.368l-.36-.213-3.76.981.999-3.671-.233-.376A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
          </svg>
          <span>WhatsApp</span>
        </a>
        <a href="/contact/" class="btn btn--primary btn--sm">Submit Enquiry</a>
      </div>

      <div style="display:flex; align-items:center; gap:0.75rem;">
        <a
          href={whatsappURL}
          target="_blank"
          rel="noopener noreferrer"
          class="navbar__whatsapp"
          aria-label="Chat on WhatsApp"
          style="display:none;"
          id="whatsapp-mobile-nav"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.555 4.122 1.528 5.855L0 24l6.335-1.652A11.954 11.954 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.003-1.368l-.36-.213-3.76.981.999-3.671-.233-.376A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
          </svg>
        </a>
        <button
          class="navbar__toggle"
          id="menu-toggle"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

    </div>

    <nav class="navbar__mobile" id="mobile-menu" aria-label="Mobile navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`navbar__mobile-link ${currentPath === link.href ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
      <a href="/contact/" class="btn btn--primary" style="margin-top: 0.5rem; text-align:center; justify-content:center;">
        Submit Enquiry
      </a>
    </nav>

  </header>

  <main id="main-content">
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer__grid">

        <div class="footer__brand">
          <a href="/" aria-label="Ayris Global - Home">
            <img src="/logo.png" alt="Ayris Global" width="148" height="40" />
          </a>
          <p class="footer__tagline">Intelligence. Connection. Growth.</p>
          <p class="footer__description">
            Bridging India's finest wellness producers with international buyers.
            Verified ingredients. Transparent sourcing. Trusted relationships.
          </p>
        </div>

        <div>
          <p class="footer__heading">Source</p>
          <ul class="footer__links">
            <li><a href="/for-buyers/"    class="footer__link">For Buyers</a></li>
            <li><a href="/for-suppliers/" class="footer__link">For Suppliers</a></li>
            <li><a href="/products/"      class="footer__link">Product Categories</a></li>
            <li><a href="/why-india/"     class="footer__link">Why India</a></li>
            <li><a href="/quality/"       class="footer__link">Quality Standards</a></li>
          </ul>
        </div>

        <div>
          <p class="footer__heading">Company</p>
          <ul class="footer__links">
            <li><a href="/about/"   class="footer__link">About Us</a></li>
            <li><a href="/blog/"    class="footer__link">Insights</a></li>
            <li><a href="/contact/" class="footer__link">Contact</a></li>
          </ul>
        </div>

        <div>
          <p class="footer__heading">Contact</p>
          <ul class="footer__links">
            <li><a href="mailto:sourcing@ayrisglobal.in" class="footer__link">sourcing@ayrisglobal.in</a></li>
            <li><a href="mailto:partnerships@ayrisglobal.in" class="footer__link">partnerships@ayrisglobal.in</a></li>
            <li>
              <a href={whatsappURL} target="_blank" rel="noopener noreferrer" class="footer__link">
                WhatsApp Us
              </a>
            </li>
            <li style="color: rgba(250,250,248,0.35); font-size: 0.8rem; margin-top: 0.5rem;">
              Mumbai, India
            </li>
          </ul>
        </div>

      </div>

      <div class="footer__bottom">
        <p class="footer__copyright">
          &copy; {new Date().getFullYear()} Ayris Global. All rights reserved.
        </p>
        <nav class="footer__legal" aria-label="Legal links">
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/terms/">Terms of Use</a>
        </nav>
      </div>
    </div>
  </footer>

  <a
    href={whatsappURL}
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-float"
    aria-label="Chat with Ayris Global on WhatsApp"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.555 4.122 1.528 5.855L0 24l6.335-1.652A11.954 11.954 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.003-1.368l-.36-.213-3.76.981.999-3.671-.233-.376A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
    </svg>
    <span class="whatsapp-float__text">Chat with us</span>
  </a>

  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar?.classList.add('scrolled');
      } else {
        navbar?.classList.remove('scrolled');
      }
    }, { passive: true });

    const toggle     = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileWA   = document.getElementById('whatsapp-mobile-nav');

    const showMobileWA = () => {
      if (window.innerWidth <= 768 && mobileWA) {
        mobileWA.style.display = 'flex';
      }
    };
    showMobileWA();
    window.addEventListener('resize', showMobileWA, { passive: true });

    toggle?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.contains('open');
      mobileMenu?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(!isOpen));
      const spans = toggle.querySelectorAll('span');
      if (!isOpen) {
        spans[0].style.transform = 'translateY(7px) rotate(45deg)';
        spans[1].style.opacity   = '0';
        spans[2].style.transform = 'translateY(-7px) rotate(-45deg)';
      } else {
        spans[0].style.transform = '';
        spans[1].style.opacity   = '';
        spans[2].style.transform = '';
      }
    });

    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
        const spans = toggle?.querySelectorAll('span');
        if (spans) {
          spans[0].style.transform = '';
          spans[1].style.opacity   = '';
          spans[2].style.transform = '';
        }
      });
    });
  </script>

</body>
</html>
