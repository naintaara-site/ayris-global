---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  author?: string;
  readingTime?: number;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  pubDate,
  category,
  author = 'Ayris Global Editorial',
  readingTime,
  image,
  imageAlt,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const categorySlug = category.toLowerCase().replace(/\s+/g, '-').replace(/[&]/g, '');

const categoryColors: Record<string, string> = {
  'Buyer Guides': '#2563EB',
  'Sourcing Intelligence': '#0F766E',
  'Certifications & Compliance': '#7C3AED',
  'Market Insights': '#B45309',
  'Ingredient Spotlights': '#15803D',
};
const badgeColor = categoryColors[category] || '#1B2B4B';
---

<BaseLayout title={`${title} | Ayris Global`} description={description}>

  <!-- Hero banner (post image or navy fallback) -->
  <section class="post-hero" style={image ? `background-image: url('${image}')` : ''}>
    <div class="post-hero__overlay"></div>
    <div class="post-hero__inner">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/blog/">Insights</a>
        <span aria-hidden="true">›</span>
        <span>{title}</span>
      </nav>

      <!-- Category badge -->
      <span class="category-badge" style={`background: ${badgeColor}`}>{category}</span>

      <!-- Title -->
      <h1 class="post-title">{title}</h1>

      <!-- Meta row -->
      <p class="post-meta">
        {author}
        <span class="post-meta__sep">·</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {readingTime && (
          <>
            <span class="post-meta__sep">·</span>
            {readingTime} min read
          </>
        )}
      </p>

    </div>
  </section>

  <!-- Body: prose + sidebar -->
  <section class="post-body">
    <div class="post-body__inner">

      <!-- Main prose column -->
      <article class="prose">
        <slot />
      </article>

      <!-- Sidebar -->
      <aside class="sidebar">

        <!-- CTA Card -->
        <div class="sidebar-cta">
          <p class="sidebar-cta__eyebrow">Ready to source?</p>
          <h3 class="sidebar-cta__heading">Talk to our sourcing team</h3>
          <p class="sidebar-cta__body">
            We work with verified Indian manufacturers to supply certified herbal ingredients to buyers across the EU, UK, USA, UAE/GCC, Japan, Korea, ANZ, SEA and LatAm.
          </p>
          <a href="/contact/" class="sidebar-cta__btn">Submit a Sourcing Enquiry</a>
          <a
            href="https://wa.me/910000000000"
            class="sidebar-cta__whatsapp"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.555 4.122 1.528 5.855L0 24l6.335-1.652A11.954 11.954 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.003-1.368l-.36-.213-3.76.981.999-3.671-.233-.376A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
            </svg>
            WhatsApp Us
          </a>
        </div>

        <!-- What We Source -->
        <div class="sidebar-box">
          <h4 class="sidebar-box__heading">What We Source</h4>
          <ul class="sidebar-box__list">
            <li>Ayurvedic Ingredients</li>
            <li>Herbal Extracts</li>
            <li>Botanical Powders</li>
            <li>Nutraceutical Ingredients</li>
            <li>Essential Oils</li>
            <li>Natural Wellness Ingredients</li>
          </ul>
          <a href="/products/" class="sidebar-box__link">View All Products →</a>
        </div>

        <!-- Related placeholder -->
        <div class="sidebar-box">
          <h4 class="sidebar-box__heading">More from Our Insights</h4>
          <ul class="sidebar-box__list sidebar-box__list--links">
            <li><a href="/blog/how-to-evaluate-indian-herbal-ingredient-supplier/">How to Evaluate an Indian Herbal Supplier</a></li>
            <li><a href="/blog/gmp-iso-fssai-organic-certification-india-herbal/">GMP, ISO, FSSAI & Organic Certifications Explained</a></li>
            <li><a href="/blog/ashwagandha-extract-buyers-guide/">Ashwagandha Extract: A Buyer's Guide</a></li>
          </ul>
        </div>

      </aside>
    </div>
  </section>

  <!-- Bottom CTA band -->
  <section class="post-cta-band">
    <div class="post-cta-band__inner">
      <h2>Have a sourcing requirement?</h2>
      <p>Tell us what you need — certifications, quantities, delivery timeline. Our team will respond within one business day.</p>
      <a href="/contact/" class="btn-primary">Start Your Sourcing Discussion</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────── */
  .post-hero {
    position: relative;
    background-color: #1B2B4B;
    background-size: cover;
    background-position: center;
    padding: 5rem 1.5rem 4rem;
    min-height: 340px;
    display: flex;
    align-items: flex-end;
  }

  .post-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(27,43,75,0.55) 0%, rgba(27,43,75,0.92) 100%);
  }

  .post-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Breadcrumb ───────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.65);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: #C9A84C; }

  .breadcrumb span:last-child {
    color: rgba(255,255,255,0.45);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 220px;
  }

  /* ── Category badge ───────────────────────────────── */
  .category-badge {
    display: inline-block;
    padding: 0.25rem 0.85rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 1rem;
  }

  /* ── Post title ───────────────────────────────────── */
  .post-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: #FAFAF8;
    line-height: 1.2;
    margin: 0 0 1rem;
    max-width: 760px;
  }

  /* ── Meta row ─────────────────────────────────────── */
  .post-meta {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-meta__sep { opacity: 0.4; }

  /* ── Body layout ──────────────────────────────────── */
  .post-body {
    background: #FAFAF8;
    padding: 4rem 1.5rem;
  }

  .post-body__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3.5rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .post-body__inner {
      grid-template-columns: 1fr;
    }
    .sidebar { order: -1; }
  }

  /* ── Prose styles ─────────────────────────────────── */
  .prose {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #2d2d2d;
  }

  .prose :global(h2) {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.65rem;
    color: #1B2B4B;
    margin: 2.5rem 0 0.85rem;
    line-height: 1.3;
  }

  .prose :global(h3) {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.25rem;
    color: #1B2B4B;
    margin: 2rem 0 0.6rem;
    line-height: 1.35;
  }

  .prose :global(p) {
    margin-bottom: 1.35rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4rem;
    margin-bottom: 1.35rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(strong) {
    color: #1B2B4B;
    font-weight: 600;
  }

  .prose :global(a) {
    color: #C9A84C;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    color: #1B2B4B;
  }

  .prose :global(blockquote) {
    border-left: 4px solid #C9A84C;
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    background: rgba(201,168,76,0.06);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: #444;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.92rem;
  }

  .prose :global(th) {
    background: #1B2B4B;
    color: #FAFAF8;
    padding: 0.65rem 1rem;
    text-align: left;
    font-weight: 600;
  }

  .prose :global(td) {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid #e8e3d9;
    vertical-align: top;
  }

  .prose :global(tr:nth-child(even) td) {
    background: rgba(27,43,75,0.03);
  }

  .prose :global(code) {
    background: rgba(27,43,75,0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.88em;
    font-family: 'Courier New', monospace;
  }

  .prose :global(hr) {
    border: none;
    border-top: 2px solid #e8e3d9;
    margin: 2.5rem 0;
  }

  /* ── Sidebar ──────────────────────────────────────── */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: sticky;
    top: 2rem;
  }

  /* CTA card */
  .sidebar-cta {
    background: #1B2B4B;
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    color: #FAFAF8;
  }

  .sidebar-cta__eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #C9A84C;
    margin: 0 0 0.4rem;
  }

  .sidebar-cta__heading {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.25rem;
    color: #FAFAF8;
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .sidebar-cta__body {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.72);
    line-height: 1.65;
    margin: 0 0 1.25rem;
  }

  .sidebar-cta__btn {
    display: block;
    background: #C9A84C;
    color: #1B2B4B;
    text-align: center;
    padding: 0.7rem 1rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.88rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    margin-bottom: 0.75rem;
  }

  .sidebar-cta__btn:hover {
    background: #d4b05a;
    transform: translateY(-1px);
  }

  .sidebar-cta__whatsapp {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.85);
    border: 1px solid rgba(255,255,255,0.15);
    text-align: center;
    padding: 0.6rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }

  .sidebar-cta__whatsapp:hover {
    background: rgba(255,255,255,0.14);
  }

  /* Generic sidebar box */
  .sidebar-box {
    background: #fff;
    border: 1px solid #e8e3d9;
    border-radius: 10px;
    padding: 1.4rem 1.35rem;
  }

  .sidebar-box__heading {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1rem;
    color: #1B2B4B;
    margin: 0 0 0.85rem;
  }

  .sidebar-box__list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.85rem;
  }

  .sidebar-box__list li {
    font-size: 0.87rem;
    color: #444;
    padding: 0.3rem 0;
    border-bottom: 1px solid #f0ece4;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .sidebar-box__list li::before {
    content: '▸';
    color: #C9A84C;
    font-size: 0.7rem;
    flex-shrink: 0;
  }

  .sidebar-box__list--links li::before { display: none; }

  .sidebar-box__list--links a {
    color: #1B2B4B;
    text-decoration: none;
    font-size: 0.86rem;
    line-height: 1.4;
    transition: color 0.2s;
  }

  .sidebar-box__list--links a:hover { color: #C9A84C; }

  .sidebar-box__link {
    font-size: 0.82rem;
    font-weight: 600;
    color: #C9A84C;
    text-decoration: none;
    display: inline-block;
    margin-top: 0.25rem;
    transition: color 0.2s;
  }

  .sidebar-box__link:hover { color: #1B2B4B; }

  /* ── Bottom CTA band ──────────────────────────────── */
  .post-cta-band {
    background: linear-gradient(135deg, #1B2B4B 0%, #243d6b 100%);
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .post-cta-band__inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .post-cta-band h2 {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: #FAFAF8;
    margin: 0 0 0.85rem;
  }

  .post-cta-band p {
    color: rgba(255,255,255,0.72);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 1.75rem;
  }

  .btn-primary {
    display: inline-block;
    background: #C9A84C;
    color: #1B2B4B;
    padding: 0.85rem 2rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-primary:hover {
    background: #d4b05a;
    transform: translateY(-2px);
  }
</style>
