---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.description}>

  <!-- Hero -->
  <section style="background: #1B2B4B; padding: 80px 24px 60px;">
    <div style="max-width: 800px; margin: 0 auto;">
      <p style="color: #C9A84C; font-family: Inter, sans-serif; font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 16px;">
        {post.data.category}
      </p>
      <h1 style="font-family: 'DM Serif Display', serif; font-size: clamp(2rem, 4vw, 3rem); color: #FAFAF8; line-height: 1.2; margin-bottom: 24px;">
        {post.data.title}
      </h1>
      <p style="color: #FAFAF8; opacity: 0.7; font-family: Inter, sans-serif; font-size: 0.95rem;">
        {formattedDate} &nbsp;·&nbsp; {post.data.readTime}
      </p>
    </div>
  </section>

  <!-- Content -->
  <section style="background: #FAFAF8; padding: 60px 24px 80px;">
    <div style="max-width: 800px; margin: 0 auto;">

      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.title}
          style="width: 100%; height: 400px; object-fit: cover; border-radius: 8px; margin-bottom: 48px;"
        />
      )}

      <div class="prose">
        <Content />
      </div>

      <!-- Back link -->
      <div style="margin-top: 64px; padding-top: 32px; border-top: 1px solid #e5e7eb;">
        <a href="/blog/" style="color: #C9A84C; font-family: Inter, sans-serif; font-weight: 600; text-decoration: none; font-size: 0.95rem;">
          ← Back to Insights
        </a>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .prose {
    font-family: Inter, sans-serif;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #1B2B4B;
  }
  .prose h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.75rem;
    color: #1B2B4B;
    margin-top: 48px;
    margin-bottom: 16px;
  }
  .prose h3 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.35rem;
    color: #1B2B4B;
    margin-top: 36px;
    margin-bottom: 12px;
  }
  .prose p {
    margin-bottom: 20px;
  }
  .prose ul, .prose ol {
    margin-bottom: 20px;
    padding-left: 24px;
  }
  .prose li {
    margin-bottom: 8px;
  }
  .prose strong {
    color: #1B2B4B;
    font-weight: 600;
  }
  .prose a {
    color: #C9A84C;
    text-decoration: underline;
  }
  .prose blockquote {
    border-left: 3px solid #C9A84C;
    padding-left: 20px;
    margin-left: 0;
    color: #4B5563;
    font-style: italic;
  }
</style>