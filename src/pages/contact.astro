<script>
  const form = document.getElementById('enquiry-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const errorMsg = document.getElementById('form-error') as HTMLElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Reset messages
      successMsg.hidden = true;
      errorMsg.hidden = true;

      // Loading state
      submitBtn.disabled = true;
      submitBtn.querySelector('.btn__text')!.textContent = 'Sendingâ€¦';

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(data),
        });

        const json = await res.json();

        if (res.ok && json.success) {
          successMsg.hidden = false;
          form.reset();
          successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          throw new Error(json.message || 'Submission failed');
        }
      } catch (err) {
        errorMsg.hidden = false;
        errorMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } finally {
        submitBtn.disabled = false;
        submitBtn.querySelector('.btn__text')!.textContent = 'Submit Enquiry';
      }
    });
  }
</script>

