---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Ayris Global — Premium Indian Botanical Ingredients, Global Supply"
  description="Ayris Global connects the world's wellness brands to India's finest botanical ingredients. GMP-certified sourcing across EU, UK, USA, UAE/GCC, Japan, Korea, ANZ, and beyond."
>

  <!-- ═══════════════════════════════════════════════
       HERO SECTION
  ════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__inner">

      <!-- BOTANICAL ARCH SVG -->
      <div class="hero__arch" aria-hidden="true">
        <svg viewBox="0 0 520 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="arch-svg">
          <!-- Left branch -->
          <path d="M260 148 Q200 120 150 90 Q110 65 80 30" stroke="#C9A84C" stroke-width="1.2" fill="none" opacity="0.7"/>
          <path d="M260 148 Q195 125 140 100 Q100 78 65 48" stroke="#C9A84C" stroke-width="0.7" fill="none" opacity="0.4"/>
          <!-- Left leaves -->
          <ellipse cx="80" cy="30" rx="7" ry="3.5" fill="#C9A84C" opacity="0.6" transform="rotate(-40 80 30)"/>
          <ellipse cx="110" cy="52" rx="5.5" ry="2.5" fill="#C9A84C" opacity="0.45" transform="rotate(-30 110 52)"/>
          <ellipse cx="145" cy="78" rx="5" ry="2.2" fill="#C9A84C" opacity="0.4" transform="rotate(-20 145 78)"/>
          <ellipse cx="65" cy="48" rx="5" ry="2" fill="#C9A84C" opacity="0.3" transform="rotate(-50 65 48)"/>
          <!-- Right branch -->
          <path d="M260 148 Q320 120 370 90 Q410 65 440 30" stroke="#C9A84C" stroke-width="1.2" fill="none" opacity="0.7"/>
          <path d="M260 148 Q325 125 380 100 Q420 78 455 48" stroke="#C9A84C" stroke-width="0.7" fill="none" opacity="0.4"/>
          <!-- Right leaves -->
          <ellipse cx="440" cy="30" rx="7" ry="3.5" fill="#C9A84C" opacity="0.6" transform="rotate(40 440 30)"/>
          <ellipse cx="410" cy="52" rx="5.5" ry="2.5" fill="#C9A84C" opacity="0.45" transform="rotate(30 410 52)"/>
          <ellipse cx="375" cy="78" rx="5" ry="2.2" fill="#C9A84C" opacity="0.4" transform="rotate(20 375 78)"/>
          <ellipse cx="455" cy="48" rx="5" ry="2" fill="#C9A84C" opacity="0.3" transform="rotate(50 455 48)"/>
          <!-- Central lotus ornament -->
          <g transform="translate(260,148)">
            <!-- Petals -->
            <ellipse cx="0" cy="-11" rx="4" ry="7" fill="#C9A84C" opacity="0.8"/>
            <ellipse cx="0" cy="-11" rx="4" ry="7" fill="#C9A84C" opacity="0.8" transform="rotate(45)"/>
            <ellipse cx="0" cy="-11" rx="4" ry="7" fill="#C9A84C" opacity="0.8" transform="rotate(90)"/>
            <ellipse cx="0" cy="-11" rx="4" ry="7" fill="#C9A84C" opacity="0.8" transform="rotate(135)"/>
            <ellipse cx="0" cy="-11" rx="4" ry="7" fill="#C9A84C" opacity="0.6" transform="rotate(22.5)"/>
            <ellipse cx="0" cy="-11" rx="4" ry="7" fill="#C9A84C" opacity="0.6" transform="rotate(67.5)"/>
            <ellipse cx="0" cy="-11" rx="4" ry="7" fill="#C9A84C" opacity="0.6" transform="rotate(112.5)"/>
            <ellipse cx="0" cy="-11" rx="4" ry="7" fill="#C9A84C" opacity="0.6" transform="rotate(157.5)"/>
            <!-- Centre -->
            <circle cx="0" cy="0" r="4.5" fill="#C9A84C" opacity="0.9"/>
            <circle cx="0" cy="0" r="2.5" fill="#1B2B4B"/>
          </g>
          <!-- Fade rule left -->
          <line x1="20" y1="155" x2="230" y2="155" stroke="url(#fadeLeft)" stroke-width="0.8"/>
          <!-- Fade rule right -->
          <line x1="290" y1="155" x2="500" y2="155" stroke="url(#fadeRight)" stroke-width="0.8"/>
          <defs>
            <linearGradient id="fadeLeft" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#C9A84C" stop-opacity="0"/>
              <stop offset="100%" stop-color="#C9A84C" stop-opacity="0.6"/>
            </linearGradient>
            <linearGradient id="fadeRight" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#C9A84C" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="#C9A84C" stop-opacity="0"/>
            </linearGradient>
          </defs>
        </svg>
      </div>

      <!-- WORDMARK -->
      <div class="hero__brand">
        <h1 class="hero__wordmark">AYRIS GLOBAL</h1>
        <div class="hero__rule-group" aria-hidden="true">
          <span class="rule rule--left"></span>
          <span class="rule__diamond"></span>
          <span class="rule rule--right"></span>
        </div>
        <p class="hero__tagline">Intelligence. Connection. Growth.</p>
      </div>

      <!-- RULE BELOW WORDMARK -->
      <div class="hero__divider" aria-hidden="true"></div>

      <!-- HERO BODY -->
      <div class="hero__body">
        <p class="hero__lead">
          India's botanical heritage, delivered to the world's leading wellness brands.
          GMP-certified ingredients. Transparent supply chains. Expert sourcing guidance.
        </p>
        <div class="hero__cta-group">
          <a href="/products/" class="btn btn--primary">Explore Ingredients</a>
          <a href="/contact/" class="btn btn--outline">Start a Sourcing Conversation</a>
        </div>
      </div>

      <!-- MARKET BADGES -->
      <div class="hero__markets">
        <span class="market-badge">EU</span>
        <span class="market-badge">UK</span>
        <span class="market-badge">USA</span>
        <span class="market-badge">UAE / GCC</span>
        <span class="market-badge">Japan</span>
        <span class="market-badge">Korea</span>
        <span class="market-badge">ANZ</span>
        <span class="market-badge">Southeast Asia</span>
        <span class="market-badge">Latin America</span>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FEATURED INGREDIENTS STRIP
  ════════════════════════════════════════════════ -->
  <section class="ingredients-strip">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Source of Wellness</span>
        <h2 class="section-title">Featured Ingredients</h2>
        <p class="section-sub">Six of India's most sought-after botanicals — each with centuries of traditional use and modern clinical validation.</p>
      </div>

      <div class="ingredients-grid">

        <a href="/products/" class="ingredient-card">
          <div class="ingredient-card__img-wrap">
            <img
              src="/images/products/ashwagandha.jpg"
              alt="Ashwagandha root and powder"
              loading="lazy"
              width="480"
              height="320"
            />
            <div class="ingredient-card__overlay"></div>
          </div>
          <div class="ingredient-card__body">
            <h3 class="ingredient-card__name">Ashwagandha</h3>
            <p class="ingredient-card__latin">Withania somnifera</p>
            <p class="ingredient-card__desc">Root extract, KSM-66 & Sensoril standardised. India's premier adaptogen — trusted by supplement brands globally.</p>
            <span class="ingredient-card__link">View specifications →</span>
          </div>
        </a>

        <a href="/products/" class="ingredient-card">
          <div class="ingredient-card__img-wrap">
            <img
              src="/images/home/turmeric-root.jpg"
              alt="Fresh turmeric root"
              loading="lazy"
              width="480"
              height="320"
            />
            <div class="ingredient-card__overlay"></div>
          </div>
          <div class="ingredient-card__body">
            <h3 class="ingredient-card__name">Turmeric</h3>
            <p class="ingredient-card__latin">Curcuma longa</p>
            <p class="ingredient-card__desc">Curcumin 95% standardised extract and whole root powder. The world's most studied anti-inflammatory botanical.</p>
            <span class="ingredient-card__link">View specifications →</span>
          </div>
        </a>

        <a href="/products/" class="ingredient-card">
          <div class="ingredient-card__img-wrap">
            <img
              src="/images/products/tulsi-extract.jpg"
              alt="Tulsi Holy Basil fresh leaves"
              loading="lazy"
              width="480"
              height="320"
            />
            <div class="ingredient-card__overlay"></div>
          </div>
          <div class="ingredient-card__body">
            <h3 class="ingredient-card__name">Tulsi</h3>
            <p class="ingredient-card__latin">Ocimum tenuiflorum</p>
            <p class="ingredient-card__desc">Holy Basil leaf powder and extract — revered in Ayurvedic tradition and in high demand from functional tea brands worldwide.</p>
            <span class="ingredient-card__link">View specifications →</span>
          </div>
        </a>

        <a href="/products/" class="ingredient-card">
          <div class="ingredient-card__img-wrap">
            <img
              src="/images/products/moringa-powder.jpg"
              alt="Moringa leaves and powder"
              loading="lazy"
              width="480"
              height="320"
            />
            <div class="ingredient-card__overlay"></div>
          </div>
          <div class="ingredient-card__body">
            <h3 class="ingredient-card__name">Moringa</h3>
            <p class="ingredient-card__latin">Moringa oleifera</p>
            <p class="ingredient-card__desc">Leaf powder and extract — a nutritional powerhouse with exceptional protein density, iron, and antioxidant profiles.</p>
            <span class="ingredient-card__link">View specifications →</span>
          </div>
        </a>

        <a href="/products/" class="ingredient-card">
          <div class="ingredient-card__img-wrap">
            <img
              src="/images/products/boswellia-extract.jpg"
              alt="Boswellia resin and bark"
              loading="lazy"
              width="480"
              height="320"
            />
            <div class="ingredient-card__overlay"></div>
          </div>
          <div class="ingredient-card__body">
            <h3 class="ingredient-card__name">Boswellia</h3>
            <p class="ingredient-card__latin">Boswellia serrata</p>
            <p class="ingredient-card__desc">Indian Frankincense — AKBA-standardised extract for joint health formulations. Preferred by European and North American nutraceutical brands.</p>
            <span class="ingredient-card__link">View specifications →</span>
          </div>
        </a>

        <a href="/products/" class="ingredient-card">
          <div class="ingredient-card__img-wrap">
            <img
              src="/images/home/cardamom-pods.jpg"
              alt="Green cardamom pods"
              loading="lazy"
              width="480"
              height="320"
            />
            <div class="ingredient-card__overlay"></div>
          </div>
          <div class="ingredient-card__body">
            <h3 class="ingredient-card__name">Cardamom</h3>
            <p class="ingredient-card__latin">Elettaria cardamomum</p>
            <p class="ingredient-card__desc">Green cardamom pods, ground powder and essential oil — Kerala-origin, prized by luxury tea blenders from London to Tokyo.</p>
            <span class="ingredient-card__link">View specifications →</span>
          </div>
        </a>

      </div>

      <div class="strip-footer">
        <a href="/products/" class="btn btn--primary">View All Ingredient Categories</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHY AYRIS GLOBAL — THREE PILLARS
  ════════════════════════════════════════════════ -->
  <section class="pillars">
    <div class="container">
      <div class="section-header section-header--light">
        <span class="section-eyebrow section-eyebrow--gold">The Ayris Difference</span>
        <h2 class="section-title section-title--dark">What We Bring to Every Sourcing Partnership</h2>
      </div>
      <div class="pillars-grid">
        <div class="pillar">
          <div class="pillar__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="22" stroke="#C9A84C" stroke-width="1.5"/>
              <path d="M16 24 Q20 16 24 14 Q28 16 32 24 Q28 32 24 34 Q20 32 16 24Z" stroke="#C9A84C" stroke-width="1.5" fill="none"/>
              <circle cx="24" cy="24" r="3" fill="#C9A84C"/>
            </svg>
          </div>
          <h3 class="pillar__title">Origin Intelligence</h3>
          <p class="pillar__text">We know India's botanical supply chain at ground level — which regions grow what, which producers hold certifications, and how seasonal variation affects quality. You get intelligence, not just a product list.</p>
        </div>
        <div class="pillar">
          <div class="pillar__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="22" stroke="#C9A84C" stroke-width="1.5"/>
              <path d="M14 34 L20 26 L26 30 L34 18" stroke="#C9A84C" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="34" cy="18" r="2.5" fill="#C9A84C"/>
            </svg>
          </div>
          <h3 class="pillar__title">Certification Depth</h3>
          <p class="pillar__text">GMP, ISO, FSSAI, Organic (NPOP/NOP), Halal, Kosher — we match the right certification stack to every market. EU Novel Food, US FDA registration, EFSA compliance: we navigate it so your procurement team doesn't have to.</p>
        </div>
        <div class="pillar">
          <div class="pillar__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="22" stroke="#C9A84C" stroke-width="1.5"/>
              <path d="M24 14 L24 24 L32 28" stroke="#C9A84C" stroke-width="1.8" stroke-linecap="round"/>
              <path d="M16 18 Q10 24 16 30" stroke="#C9A84C" stroke-width="1.2" fill="none" stroke-linecap="round"/>
              <path d="M32 18 Q38 24 32 30" stroke="#C9A84C" stroke-width="1.2" fill="none" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="pillar__title">Responsive Partnership</h3>
          <p class="pillar__text">Sample requests, specification sheets, CoA/MSDS documentation, pricing — handled with the speed your product development timelines demand. One point of contact from first enquiry to delivered shipment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CREDENTIALS BAR
  ════════════════════════════════════════════════ -->
  <section class="credentials">
    <div class="container">
      <div class="credentials-bar">
        <div class="credential">
          <span class="credential__badge">GMP</span>
          <span class="credential__label">Certified Suppliers</span>
        </div>
        <div class="credential">
          <span class="credential__badge">ISO</span>
          <span class="credential__label">22000 / 9001</span>
        </div>
        <div class="credential">
          <span class="credential__badge">FSSAI</span>
          <span class="credential__label">Licensed</span>
        </div>
        <div class="credential">
          <span class="credential__badge">Organic</span>
          <span class="credential__label">NPOP / NOP</span>
        </div>
        <div class="credential">
          <span class="credential__badge">Halal</span>
          <span class="credential__label">Certified</span>
        </div>
        <div class="credential">
          <span class="credential__badge">Kosher</span>
          <span class="credential__label">Available</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CTA BAND
  ════════════════════════════════════════════════ -->
  <section class="cta-band">
    <div class="container">
      <div class="cta-band__inner">
        <h2 class="cta-band__title">Ready to source from India's finest producers?</h2>
        <p class="cta-band__sub">Whether you're formulating a new product line or looking for a more reliable supply partner, we'd welcome a conversation.</p>
        <div class="cta-band__actions">
          <a href="/contact/" class="btn btn--primary btn--lg">Start a Sourcing Conversation</a>
          <a href="/for-buyers/" class="btn btn--ghost btn--lg">Why Buyers Choose Ayris Global</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─────────────────────────────────────────────
     HERO
  ───────────────────────────────────────────── */
  .hero {
    background-color: #1B2B4B;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 1.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(201,168,76,0.10) 0%, transparent 70%),
      radial-gradient(ellipse 40% 30% at 50% 100%, rgba(201,168,76,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__inner {
    max-width: 820px;
    width: 100%;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  /* Botanical arch */
  .hero__arch {
    margin-bottom: -0.5rem;
  }

  .arch-svg {
    width: 100%;
    max-width: 520px;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  /* Wordmark */
  .hero__brand {
    margin-bottom: 1.5rem;
  }

  .hero__wordmark {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(3.5rem, 9vw, 7rem);
    font-weight: 400;
    letter-spacing: 0.12em;
    line-height: 1;
    margin: 0 0 0.75rem;
    background: linear-gradient(
      135deg,
      #b8922a 0%,
      #C9A84C 18%,
      #e8d08a 32%,
      #f5e8b0 44%,
      #C9A84C 56%,
      #b8922a 68%,
      #C9A84C 78%,
      #e8d08a 88%,
      #b8922a 100%
    );
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 6s ease-in-out infinite;
    filter: drop-shadow(0 0 28px rgba(201,168,76,0.35)) drop-shadow(0 2px 8px rgba(0,0,0,0.5));
  }

  @keyframes shimmer {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Three-segment fade rule */
  .hero__rule-group {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-bottom: 0.9rem;
  }

  .rule {
    display: block;
    height: 1px;
    width: clamp(60px, 12vw, 120px);
  }

  .rule--left {
    background: linear-gradient(to right, transparent, rgba(201,168,76,0.7));
  }

  .rule--right {
    background: linear-gradient(to left, transparent, rgba(201,168,76,0.7));
  }

  .rule__diamond {
    display: block;
    width: 6px;
    height: 6px;
    background: #C9A84C;
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .hero__tagline {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.7rem, 1.5vw, 0.85rem);
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.75);
    margin: 0;
  }

  /* Divider below brand */
  .hero__divider {
    width: 40px;
    height: 1px;
    background: rgba(201,168,76,0.3);
    margin: 1.8rem auto;
  }

  .hero__lead {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    color: rgba(250,250,248,0.85);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto 2.2rem;
    font-weight: 300;
  }

  .hero__cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  /* Market badges */
  .hero__markets {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .market-badge {
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.65);
    border: 1px solid rgba(201,168,76,0.2);
    padding: 0.25rem 0.65rem;
    border-radius: 2px;
  }

  /* ─────────────────────────────────────────────
     BUTTONS (global within this page)
  ───────────────────────────────────────────── */
  .btn {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-decoration: none;
    padding: 0.85rem 1.8rem;
    border-radius: 3px;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .btn--primary {
    background: #C9A84C;
    color: #1B2B4B;
    border: 2px solid #C9A84C;
  }

  .btn--primary:hover {
    background: #b8922a;
    border-color: #b8922a;
  }

  .btn--outline {
    background: transparent;
    color: #C9A84C;
    border: 2px solid rgba(201,168,76,0.6);
  }

  .btn--outline:hover {
    border-color: #C9A84C;
    background: rgba(201,168,76,0.08);
  }

  .btn--ghost {
    background: transparent;
    color: #FAFAF8;
    border: 2px solid rgba(250,250,248,0.3);
  }

  .btn--ghost:hover {
    border-color: rgba(250,250,248,0.7);
    background: rgba(250,250,248,0.05);
  }

  .btn--lg {
    padding: 1rem 2.2rem;
    font-size: 0.9rem;
  }

  /* ─────────────────────────────────────────────
     CONTAINER
  ───────────────────────────────────────────── */
  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ─────────────────────────────────────────────
     SECTION HEADERS
  ───────────────────────────────────────────── */
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #C9A84C;
    margin-bottom: 0.75rem;
  }

  .section-eyebrow--gold { color: #C9A84C; }

  .section-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 400;
    color: #1B2B4B;
    margin: 0 0 1rem;
    line-height: 1.2;
  }

  .section-title--dark { color: #1B2B4B; }

  .section-sub {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: #555;
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ─────────────────────────────────────────────
     FEATURED INGREDIENTS STRIP
  ───────────────────────────────────────────── */
  .ingredients-strip {
    background: #FAFAF8;
    padding: 6rem 0 5rem;
  }

  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }

