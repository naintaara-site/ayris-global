---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Ingredient Categories — Ayris Global"
  description="Explore Ayris Global's full range of premium Indian botanical ingredients: Ayurvedic ingredients, herbal extracts, botanical powders, nutraceuticals, essential oils, and natural wellness ingredients. GMP-certified, globally supplied."
>

  <!-- ═══════════════════════════════════
       PAGE HERO
  ════════════════════════════════════ -->
  <section class="page-hero">
    <div class="page-hero__inner">
      <span class="eyebrow">What We Source</span>
      <h1 class="page-hero__title">Ingredient Categories</h1>
      <p class="page-hero__sub">Six category families. Hundreds of individual ingredients. Every one sourced from GMP-certified, audit-ready Indian producers — and matched to the specific market requirements of your region.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       CATEGORY 1: AYURVEDIC INGREDIENTS
  ════════════════════════════════════ -->
  <section class="category" id="ayurvedic">
    <div class="container">
      <div class="category__layout">

        <div class="category__hero">
          <img
            src="https://images.unsplash.com/photo-1768729340731-85e386e62529?w=700&h=500&fit=crop&auto=format"
            alt="Traditional Ayurvedic preparation with mortar and pestle, Gujarat India"
            loading="lazy"
            width="700"
            height="500"
          />
          <div class="category__hero-badge">
            <span>Category 01</span>
          </div>
        </div>

        <div class="category__content">
          <span class="category__eyebrow">5,000 years of tradition</span>
          <h2 class="category__title">Ayurvedic Ingredients</h2>
          <p class="category__desc">The foundational botanicals of Ayurveda — India's classical system of medicine. These are the adaptogens, rasayanas, and tonic herbs that global supplement brands, functional food producers, and wellness formulators are building their most credible product lines around.</p>
          <ul class="category__certs">
            <li>GMP certified</li>
            <li>FSSAI licensed</li>
            <li>Organic (NPOP/NOP)</li>
            <li>Standardised extracts available</li>
          </ul>

          <div class="ingredient-cards">

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1569936906148-06de87cb0681?w=320&h=220&fit=crop&auto=format" alt="Ashwagandha plant" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Ashwagandha</h3>
                <p class="latin">Withania somnifera</p>
                <p>Root extract (KSM-66, Sensoril standardised), root powder. The world's most commercially significant Ayurvedic adaptogen.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1741513599050-487ccfb86275?w=320&h=220&fit=crop&auto=format" alt="Shatavari root" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Shatavari</h3>
                <p class="latin">Asparagus racemosus</p>
                <p>Root powder and extract. A leading women's wellness tonic — growing demand across EU nutraceutical and functional food sectors.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1538596313828-41d729090199?w=320&h=220&fit=crop&auto=format" alt="Brahmi plant" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Brahmi</h3>
                <p class="latin">Bacopa monnieri</p>
                <p>Aerial extract standardised to bacosides. A nootropic ingredient in strong demand from UK, USA, Japan and Korean cognitive supplement markets.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       CATEGORY 2: HERBAL EXTRACTS
  ════════════════════════════════════ -->
  <section class="category category--alt" id="extracts">
    <div class="container">
      <div class="category__layout category__layout--reverse">

        <div class="category__hero">
          <img
            src="https://images.unsplash.com/photo-1515377905703-c4788e51af15?w=700&h=500&fit=crop&auto=format"
            alt="Amber glass dropper bottle containing herbal extract"
            loading="lazy"
            width="700"
            height="500"
          />
          <div class="category__hero-badge">
            <span>Category 02</span>
          </div>
        </div>

        <div class="category__content">
          <span class="category__eyebrow">Precision standardisation</span>
          <h2 class="category__title">Herbal Extracts</h2>
          <p class="category__desc">Concentrated botanical extracts with defined active content — standardised by HPLC, UV, or gravimetric methods. Supplied as dry powders, liquid extracts, or encapsulated forms. Each batch accompanied by full CoA, MSDS, and origin documentation.</p>
          <ul class="category__certs">
            <li>HPLC-standardised actives</li>
            <li>ISO 22000 / ISO 9001</li>
            <li>Halal & Kosher available</li>
            <li>EU, UK, US import-ready</li>
          </ul>

          <div class="ingredient-cards">

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1490175677764-12ef5f1eaf87?w=320&h=220&fit=crop&auto=format" alt="Tulsi holy basil leaves extract" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Tulsi Extract</h3>
                <p class="latin">Ocimum tenuiflorum</p>
                <p>Leaf extract standardised to ursolic acid and eugenol. Adaptogenic, antimicrobial — highly sought by functional tea and supplement brands in ANZ, USA and UK.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1642049671748-2e35cdb11c2c?w=320&h=220&fit=crop&auto=format" alt="Boswellia frankincense resin" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Boswellia Extract</h3>
                <p class="latin">Boswellia serrata</p>
                <p>AKBA-standardised Indian frankincense extract. The leading joint health ingredient in European and North American nutraceutical markets.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1569936906148-06de87cb0681?w=320&h=220&fit=crop&auto=format" alt="Guduchi plant extract" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Guduchi Extract</h3>
                <p class="latin">Tinospora cordifolia</p>
                <p>Stem extract standardised to tinosporin. A premier Ayurvedic immunomodulator with growing clinical validation and rising demand across EU and Korean markets.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       CATEGORY 3: BOTANICAL POWDERS
  ════════════════════════════════════ -->
  <section class="category" id="powders">
    <div class="container">
      <div class="category__layout">

        <div class="category__hero">
          <img
            src="https://images.unsplash.com/photo-1565117834327-efcb6a1d55a1?w=700&h=500&fit=crop&auto=format"
            alt="Fine green botanical powder on wooden spoon"
            loading="lazy"
            width="700"
            height="500"
          />
          <div class="category__hero-badge">
            <span>Category 03</span>
          </div>
        </div>

        <div class="category__content">
          <span class="category__eyebrow">Whole ingredient integrity</span>
          <h2 class="category__title">Botanical Powders</h2>
          <p class="category__desc">Whole-plant and single-part botanical powders — dried, milled, and sieved to specification. Used in finished supplements, functional foods, teas, smoothie blends, and cosmetic formulations. Available in conventional, organic, and spray-dried formats.</p>
          <ul class="category__certs">
            <li>Organic NPOP / NOP certified</li>
            <li>Mesh size to specification</li>
            <li>Heavy metal tested</li>
            <li>Pesticide residue screened</li>
          </ul>

          <div class="ingredient-cards">

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1490175677764-12ef5f1eaf87?w=320&h=220&fit=crop&auto=format" alt="Moringa leaf powder" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Moringa Powder</h3>
                <p class="latin">Moringa oleifera</p>
                <p>Leaf powder — a complete protein source with exceptional iron and antioxidant profiles. In high demand from EU health food brands, SEA wellness markets, and LatAm functional food producers.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1565117834327-efcb6a1d55a1?w=320&h=220&fit=crop&auto=format" alt="Amla Indian gooseberry powder" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Amla Powder</h3>
                <p class="latin">Phyllanthus emblica</p>
                <p>Indian gooseberry fruit powder — one of the richest natural sources of Vitamin C. A star ingredient for immunity, hair wellness, and antioxidant supplement formulations worldwide.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1538596313828-41d729090199?w=320&h=220&fit=crop&auto=format" alt="Neem leaf powder" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Neem Powder</h3>
                <p class="latin">Azadirachta indica</p>
                <p>Leaf and seed powder. Widely used in cosmetic formulations, nutraceutical capsules, and functional wellness products across EU, UK and Middle East markets.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       CATEGORY 4: NUTRACEUTICAL INGREDIENTS
  ════════════════════════════════════ -->
  <section class="category category--alt" id="nutraceuticals">
    <div class="container">
      <div class="category__layout category__layout--reverse">

        <div class="category__hero">
          <img
            src="https://images.unsplash.com/photo-1734607402878-eeb4233cea86?w=700&h=500&fit=crop&auto=format"
            alt="Ayurvedic supplement bottles and wellness products"
            loading="lazy"
            width="700"
            height="500"
          />
          <div class="category__hero-badge">
            <span>Category 04</span>
          </div>
        </div>

        <div class="category__content">
          <span class="category__eyebrow">Active ingredient science</span>
          <h2 class="category__title">Nutraceutical Ingredients</h2>
          <p class="category__desc">Active botanical ingredients for inclusion in dietary supplements, functional foods, and nutraceutical formulations. Supplied with full technical documentation — CoA, MSDS, stability data, and bioavailability references — to meet the procurement standards of regulated markets globally.</p>
          <ul class="category__certs">
            <li>GMP, ISO 22000</li>
            <li>EU Novel Food status guidance</li>
            <li>FDA facility registered</li>
            <li>Full technical dossier available</li>
          </ul>

          <div class="ingredient-cards">

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1741513599050-487ccfb86275?w=320&h=220&fit=crop&auto=format" alt="Turmeric curcumin root" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Curcumin (Turmeric Extract)</h3>
                <p class="latin">Curcuma longa</p>
                <p>95% curcuminoids standardised, BCM-95 and CurcuWIN formats available. The world's most studied botanical anti-inflammatory — core to supplement lines in every major global market.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1758657996330-095d08451cd9?w=320&h=220&fit=crop&auto=format" alt="Black pepper piperine spice" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Piperine (Black Pepper Extract)</h3>
                <p class="latin">Piper nigrum</p>
                <p>95% piperine standardised. The bioavailability enhancer found in the majority of premium curcumin, ashwagandha, and fat-soluble vitamin formulations globally.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1768729340731-85e386e62529?w=320&h=220&fit=crop&auto=format" alt="Triphala Ayurvedic formula" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Triphala</h3>
                <p class="latin">Amla, Haritaki, Bibhitaki</p>
                <p>The foundational Ayurvedic three-fruit formula — standardised extract and traditional powder. In strong demand from digestive wellness and longevity supplement markets in USA, EU and Japan.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       CATEGORY 5: ESSENTIAL OILS
  ════════════════════════════════════ -->
  <section class="category" id="essential-oils">
    <div class="container">
      <div class="category__layout">

        <div class="category__hero">
          <img
            src="https://images.unsplash.com/photo-1671492246169-cdd6305870a0?w=700&h=500&fit=crop&auto=format"
            alt="Three essential oil bottles on white surface"
            loading="lazy"
            width="700"
            height="500"
          />
          <div class="category__hero-badge">
            <span>Category 05</span>
          </div>
        </div>

        <div class="category__content">
          <span class="category__eyebrow">Steam-distilled, cold-pressed, CO₂ extracted</span>
          <h2 class="category__title">Essential Oils</h2>
          <p class="category__desc">India is one of the world's most important origins for essential oil production — from steam-distilled spice oils in Kerala to CO₂-extracted botanical oils from Rajasthan and Uttarakhand. Supplied in full GC/MS-tested batches with complete quality documentation.</p>
          <ul class="category__certs">
            <li>GC/MS tested, batch certified</li>
            <li>IFRA compliance guidance</li>
            <li>Food grade and cosmetic grade</li>
            <li>Halal certified available</li>
          </ul>

          <div class="ingredient-cards">

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1758657996330-095d08451cd9?w=320&h=220&fit=crop&auto=format" alt="Cardamom essential oil" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Cardamom Oil</h3>
                <p class="latin">Elettaria cardamomum</p>
                <p>Steam-distilled from Kerala green cardamom pods. Prized in luxury fragrance, food flavouring, and aromatherapy applications from Europe to Japan.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1515377905703-c4788e51af15?w=320&h=220&fit=crop&auto=format" alt="Vetiver essential oil amber bottle" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Vetiver Oil</h3>
                <p class="latin">Chrysopogon zizanioides</p>
                <p>Indian vetiver (khus) — steam-distilled root oil with a distinctive earthy, woody profile. A key base note in luxury fragrances and a growing ingredient in ayurvedic skincare formulations.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1741513599050-487ccfb86275?w=320&h=220&fit=crop&auto=format" alt="Ginger essential oil root" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Ginger Oil</h3>
                <p class="latin">Zingiber officinale</p>
                <p>CO₂ and steam-distilled from Indian ginger rhizomes. Used in food flavouring, digestive wellness formulations, and sports recovery products across all major global markets.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       CATEGORY 6: NATURAL WELLNESS
  ════════════════════════════════════ -->
  <section class="category category--alt" id="natural-wellness">
    <div class="container">
      <div class="category__layout category__layout--reverse">

        <div class="category__hero">
          <img
            src="https://images.unsplash.com/photo-1517162028430-9fec801e1a6b?w=700&h=500&fit=crop&auto=format"
            alt="Vibrant red hibiscus botanical flower"
            loading="lazy"
            width="700"
            height="500"
          />
          <div class="category__hero-badge">
            <span>Category 06</span>
          </div>
        </div>

        <div class="category__content">
          <span class="category__eyebrow">Flowers, roots & botanicals</span>
          <h2 class="category__title">Natural Wellness Ingredients</h2>
          <p class="category__desc">Edible botanicals, functional flowers, and wellness-grade plant ingredients used in herbal teas, functional beverages, beauty supplements, and natural cosmetic formulations. From Himalayan rose petals to South Indian hibiscus — sourced at origin, processed to specification.</p>
          <ul class="category__certs">
            <li>Food-grade processing</li>
            <li>Organic NPOP certified</li>
            <li>GMP handling and storage</li>
            <li>Functional beverage grade</li>
          </ul>

          <div class="ingredient-cards">

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1518531933037-91b2f5f229cc?w=320&h=220&fit=crop&auto=format" alt="Rose petals dried" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Rose Petals</h3>
                <p class="latin">Rosa damascena</p>
                <p>Dried and whole rose petals from Rajasthan and Uttarakhand — used in luxury herbal teas, Ayurvedic skincare, and beauty supplement formulations across EU, UAE/GCC and Korean markets.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1517162028430-9fec801e1a6b?w=320&h=220&fit=crop&auto=format" alt="Hibiscus flowers" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Hibiscus</h3>
                <p class="latin">Hibiscus sabdariffa</p>
                <p>Dried calyx — a vibrant functional botanical used in herbal teas, functional beverages, and wellness formulations. Strong demand from EU, USA, and LatAm markets for its colour, flavour, and antioxidant content.</p>
              </div>
            </div>

            <div class="ingredient-card--sm">
              <div class="ingredient-card--sm__img">
                <img src="https://images.unsplash.com/photo-1603394633635-c95b9f6f7d9c?w=320&h=220&fit=crop&auto=format" alt="Chamomile flowers dried" loading="lazy" width="320" height="220"/>
              </div>
              <div class="ingredient-card--sm__body">
                <h3>Chamomile</h3>
                <p class="latin">Matricaria chamomilla</p>
                <p>Dried chamomile flowers — whole and cut grades available. A consistent top-seller in herbal tea blends globally, from UK high-street brands to Japanese wellness subscription boxes.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       DOCUMENTATION STRIP
  ════════════════════════════════════ -->
  <section class="doc-strip">
    <div class="container">
      <div class="doc-strip__inner">
        <h2 class="doc-strip__title">Every ingredient comes fully documented</h2>
        <p class="doc-strip__sub">We know that documentation is the difference between a sample that converts and one that stalls in your procurement process. Every ingredient we supply comes with a complete documentation package — matched to your market's specific import requirements.</p>
        <div class="doc-grid">
          <div class="doc-item">
            <span class="doc-item__icon">CoA</span>
            <span class="doc-item__label">Certificate of Analysis</span>
          </div>
          <div class="doc-item">
            <span class="doc-item__icon">MSDS</span>
            <span class="doc-item__label">Safety Data Sheet</span>
          </div>
          <div class="doc-item">
            <span class="doc-item__icon">Phyto</span>
            <span class="doc-item__label">Phytosanitary Certificate</span>
          </div>
          <div class="doc-item">
            <span class="doc-item__icon">GMP</span>
            <span class="doc-item__label">GMP Certification</span>
          </div>
          <div class="doc-item">
            <span class="doc-item__icon">Org</span>
            <span class="doc-item__label">Organic Certificate (NPOP/NOP)</span>
          </div>
          <div class="doc-item">
            <span class="doc-item__icon">Halal</span>
            <span class="doc-item__label">Halal / Kosher Certification</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       CTA
  ════════════════════════════════════ -->
  <section class="cta-band">
    <div class="container">
      <div class="cta-band__inner">
        <h2 class="cta-band__title">Don't see what you're looking for?</h2>
        <p class="cta-band__sub">Our sourcing capability extends well beyond this list. If you need a specific Indian botanical ingredient — in a particular form, grade, or certification — start a conversation and we'll tell you what we can do.</p>
        <div class="cta-band__actions">
          <a href="/contact/" class="btn btn--primary btn--lg">Submit a Sourcing Enquiry</a>
          <a href="/for-buyers/" class="btn btn--ghost btn--lg">Why Buyers Choose Ayris Global</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─────────────────────────────
     PAGE HERO
  ───────────────────────────── */
  .page-hero {
    background: #1B2B4B;
    padding: 7rem 1.5rem 5rem;
    text-align: center;
  }

  .page-hero__inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.75);
    margin-bottom: 1rem;
  }

  .page-hero__title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 400;
    color: #FAFAF8;
    margin: 0 0 1.2rem;
    letter-spacing: 0.02em;
  }

  .page-hero__sub {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    color: rgba(250,250,248,0.75);
    line-height: 1.75;
    margin: 0;
    font-weight: 300;
  }

  /* ─────────────────────────────
     CONTAINER
  ───────────────────────────── */
  .container {
    max-width: 1180px;
